{
  "openapi": "3.1.0",
  "info": {
    "title": "FastAPI",
    "version": "0.1.0"
  },
  "paths": {
    "/auth/github/login": {
      "get": {
        "summary": "Github Login",
        "operationId": "github_login",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/auth/github/callback": {
      "get": {
        "summary": "Github Callback",
        "operationId": "github_callback",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Code"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "State"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/pending": {
      "get": {
        "summary": "Pending Signup",
        "description": "The GitHub profile waiting on a handle, for the /register page.",
        "operationId": "pending_signup",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PendingSignupOut"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Register",
        "description": "Complete a pending GitHub signup with the chosen handle.",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "boolean"
                  },
                  "type": "object",
                  "title": "Response Logout"
                }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Me",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserOut"
                }
              }
            }
          }
        }
      }
    },
    "/me/tokens": {
      "get": {
        "summary": "List Tokens",
        "description": "The logged-in user's API tokens (prefix + timestamps, never plaintext).",
        "operationId": "list_tokens",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ApiTokenOut"
                  },
                  "type": "array",
                  "title": "Response List Tokens"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Token",
        "description": "Mint a CLI API token for the logged-in user (shown once).",
        "operationId": "create_token",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenOut"
                }
              }
            }
          }
        }
      }
    },
    "/me/tokens/{token_id}": {
      "delete": {
        "summary": "Revoke Token",
        "operationId": "revoke_token",
        "parameters": [
          {
            "name": "token_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Token Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "boolean"
                  },
                  "title": "Response Revoke Token"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/registry/token": {
      "get": {
        "summary": "Registry Token",
        "description": "Docker Registry v2 token endpoint (the registry's `auth.token.realm`).\n\nAuthenticates the ``mp_`` token sent as the HTTP Basic password (written by\n``machineplay login``) and mints a signed JWT granting the requested scopes.",
        "operationId": "registry_token",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistryTokenOut"
                }
              }
            }
          }
        }
      }
    },
    "/engine": {
      "get": {
        "summary": "List Engines",
        "operationId": "list_engines",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/EngineOut"
                  },
                  "type": "array",
                  "title": "Response List Engines"
                }
              }
            }
          }
        }
      }
    },
    "/engine/register": {
      "post": {
        "summary": "Register Engine",
        "description": "Record an engine version after the CLI pushed its image to the registry.",
        "operationId": "register_engine",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EngineRegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EngineRegisterResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/u/{login}": {
      "get": {
        "summary": "User Profile",
        "description": "Public profile: the user, their engines, and those engines' games.",
        "operationId": "user_profile",
        "parameters": [
          {
            "name": "login",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Login"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/u/{login}/{engine_name}": {
      "get": {
        "summary": "Get Engine By Name",
        "description": "Engine detail addressed GitHub-style: owner handle + engine name.",
        "operationId": "get_engine_by_name",
        "parameters": [
          {
            "name": "login",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Login"
            }
          },
          {
            "name": "engine_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Engine Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EngineDetailOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/runners": {
      "get": {
        "summary": "List Runners",
        "operationId": "list_runners",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RunnerOut"
                  },
                  "type": "array",
                  "title": "Response List Runners"
                }
              }
            }
          }
        }
      }
    },
    "/game": {
      "post": {
        "summary": "Start Game",
        "operationId": "start_game",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartGameRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartGameResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List Games",
        "operationId": "list_games",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200,
              "minimum": 1,
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GameOut"
                  },
                  "title": "Response List Games"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/game/{game_id}": {
      "get": {
        "summary": "Get Game",
        "operationId": "get_game",
        "parameters": [
          {
            "name": "game_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Game Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stream/game/{game_id}": {
      "get": {
        "summary": "Sse Stream",
        "operationId": "sse_stream",
        "parameters": [
          {
            "name": "game_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Game Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/event-stream": {
                "itemSchema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "string"
                    },
                    "event": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string"
                    },
                    "retry": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                },
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/FenEvent"
                    },
                    {
                      "$ref": "#/components/schemas/GameStartEvent"
                    },
                    {
                      "$ref": "#/components/schemas/MoveEvent"
                    },
                    {
                      "$ref": "#/components/schemas/GameEndEvent"
                    }
                  ],
                  "discriminator": {
                    "propertyName": "type",
                    "mapping": {
                      "fen": "#/components/schemas/FenEvent",
                      "game_start": "#/components/schemas/GameStartEvent",
                      "move": "#/components/schemas/MoveEvent",
                      "game_end": "#/components/schemas/GameEndEvent"
                    }
                  },
                  "title": "Response 200 Sse Stream"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stream/live": {
      "get": {
        "summary": "Sse Live Stream",
        "operationId": "sse_live_stream",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/LiveStreamEvent"
                },
                "itemSchema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "string"
                    },
                    "event": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string"
                    },
                    "retry": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiTokenOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "prefix": {
            "type": "string",
            "title": "Prefix"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "last_used_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Used At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "prefix",
          "created_at",
          "last_used_at"
        ],
        "title": "ApiTokenOut"
      },
      "EngineDetailOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "owner_login": {
            "type": "string",
            "title": "Owner Login"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "versions": {
            "items": {
              "$ref": "#/components/schemas/EngineVersionOut"
            },
            "type": "array",
            "title": "Versions"
          },
          "games": {
            "items": {
              "$ref": "#/components/schemas/GameOut"
            },
            "type": "array",
            "title": "Games"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "owner_login",
          "created_at",
          "versions",
          "games"
        ],
        "title": "EngineDetailOut"
      },
      "EngineOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "owner_login": {
            "type": "string",
            "title": "Owner Login"
          },
          "version_count": {
            "type": "integer",
            "title": "Version Count",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "owner_login"
        ],
        "title": "EngineOut"
      },
      "EngineRegisterRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "repository": {
            "type": "string",
            "title": "Repository"
          },
          "digest": {
            "type": "string",
            "title": "Digest"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "name",
          "version",
          "repository",
          "digest"
        ],
        "title": "EngineRegisterRequest"
      },
      "EngineRegisterResponse": {
        "properties": {
          "engine_id": {
            "type": "string",
            "format": "uuid",
            "title": "Engine Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "owner_login": {
            "type": "string",
            "title": "Owner Login"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "url": {
            "type": "string",
            "title": "Url"
          }
        },
        "type": "object",
        "required": [
          "engine_id",
          "name",
          "owner_login",
          "version",
          "url"
        ],
        "title": "EngineRegisterResponse"
      },
      "EngineVersionOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes"
          },
          "image_repository": {
            "type": "string",
            "title": "Image Repository"
          },
          "image_digest": {
            "type": "string",
            "title": "Image Digest"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "version",
          "size_bytes",
          "image_repository",
          "image_digest",
          "created_at"
        ],
        "title": "EngineVersionOut"
      },
      "FenEvent": {
        "properties": {
          "type": {
            "type": "string",
            "const": "fen",
            "title": "Type",
            "default": "fen"
          },
          "fen": {
            "type": "string",
            "title": "Fen"
          },
          "ply": {
            "type": "integer",
            "title": "Ply"
          },
          "white_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "White Name"
          },
          "black_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Black Name"
          },
          "moves": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Moves"
          },
          "white_clock": {
            "type": "number",
            "title": "White Clock"
          },
          "black_clock": {
            "type": "number",
            "title": "Black Clock"
          },
          "result": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          },
          "status": {
            "$ref": "#/components/schemas/GameStatus"
          },
          "game_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Game Id"
          }
        },
        "type": "object",
        "required": [
          "fen",
          "ply",
          "white_name",
          "black_name",
          "moves",
          "white_clock",
          "black_clock",
          "result",
          "status",
          "game_id"
        ],
        "title": "FenEvent"
      },
      "GameEndEvent": {
        "properties": {
          "type": {
            "type": "string",
            "const": "game_end",
            "title": "Type",
            "default": "game_end"
          },
          "result": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          },
          "pgn": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pgn"
          }
        },
        "type": "object",
        "required": [
          "result"
        ],
        "title": "GameEndEvent"
      },
      "GameOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "white_id": {
            "type": "string",
            "format": "uuid",
            "title": "White Id"
          },
          "black_id": {
            "type": "string",
            "format": "uuid",
            "title": "Black Id"
          },
          "white_name": {
            "type": "string",
            "title": "White Name"
          },
          "black_name": {
            "type": "string",
            "title": "Black Name"
          },
          "white_version": {
            "type": "string",
            "title": "White Version"
          },
          "black_version": {
            "type": "string",
            "title": "Black Version"
          },
          "status": {
            "$ref": "#/components/schemas/GameStatus"
          },
          "result": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          },
          "moves": {
            "items": {
              "type": "string"
            },
